# Copie este arquivo para .env e preencha os valores.
# Nunca commite o arquivo .env (ele já está no .gitignore).

# Supabase (obrigatório)
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=sua-anon-key

# Gemini - para "Gerar Insights com IA" no questionário
# Obtenha em: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Server-side AI providers (API only, never expose in client code)
SUPABASE_SERVICE_ROLE_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Storage API CORS - obrigatório em produção; default localhost em dev
# Erro "Origin not allowed"? Adicione a URL do frontend aqui (vírgula para múltiplas).
# Local: http://localhost:3000,http://127.0.0.1:3000
# Produção: https://seu-app.vercel.app,https://seu-dominio.com
# STORAGE_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://seu-app.vercel.app

# Backblaze B2 Storage (obrigatório para upload de arquivos)
VITE_B2_ENDPOINT=https://s3.us-east-005.backblazeb2.com
VITE_B2_REGION=us-east-005
VITE_B2_BUCKET=pecuaria
VITE_B2_KEY_ID=
VITE_B2_APP_KEY=

# Webhook (se usar)
# N8N_WEBHOOK_URL=https://...
